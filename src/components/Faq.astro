---
import Eyebrow from './Eyebrow.astro';
const faqs = [
  { q: "How is the mentorship structured?", a: "7 chapters covering market architecture through a full personal trading plan, with 99 individual classes in total." },
  { q: "Where do I watch the classes?", a: "Inside your private members area on this site. Stream on any device — nothing to download or install." },
  { q: "Can I buy just one chapter?", a: "Yes. Tier 1 lets you unlock chapters individually. All 7 that way totals $99 — the full bundle is $79." },
  { q: "Why is the bundle cheaper than the chapters?", a: "The bundle is the intended way in: all 7 chapters and 99 classes for $79 instead of $99 chapter by chapter, with Priority Support included." },
  { q: "Do I get future classes?", a: "Yes. New classes added to the curriculum are included with the full bundle." }
];
---
<section id="faq" class="max-w-2xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="text-center mb-12 reveal">
    <Eyebrow text="FAQ" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">Questions, answered</h2>
  </div>
  <div class="divide-y divide-gray-100">
    {faqs.map((f) => (
      <details class="group py-5">
        <summary class="flex items-center justify-between cursor-pointer list-none">
          <span class="font-medium text-[15px] text-gray-950 pr-6">{f.q}</span>
          <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <p class="mt-3 text-sm text-gray-500 leading-relaxed">{f.a}</p>
      </details>
    ))}
  </div>
</section>
