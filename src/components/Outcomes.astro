---
import Eyebrow from './Eyebrow.astro';
const points = [
  { title: "Read any chart with intent", desc: "Understand why price moves before it moves — structure, liquidity, and time." },
  { title: "Trade a real, tested plan", desc: "Stop guessing. Follow the exact framework we use, filtered to only high-probability setups." },
  { title: "Get and stay funded", desc: "The mindset and rules that pass prop challenges and keep you in the game." }
];
---
<section id="outcomes" class="max-w-5xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="max-w-xl mb-14 reveal">
    <Eyebrow text="What you walk away with" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">Not more theory. A repeatable edge.</h2>
    <p class="text-gray-500 mt-4 text-lg leading-relaxed">Every chapter builds toward one thing: a trading process you can actually run.</p>
  </div>
  <div class="grid sm:grid-cols-3 gap-x-8 gap-y-10">
    {points.map((p) => (
      <div class="reveal">
        <div class="w-9 h-9 rounded-lg border border-gray-200 flex items-center justify-center">
          <svg class="w-4.5 h-4.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="mt-5 font-semibold text-[15px] text-gray-950">{p.title}</h3>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">{p.desc}</p>
      </div>
    ))}
  </div>
</section>
