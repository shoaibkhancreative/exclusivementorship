---
import Eyebrow from './Eyebrow.astro';
import testimonials from '../data/testimonials.json';
---
<section id="testimonials" class="max-w-5xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="max-w-xl mb-14 reveal">
    <Eyebrow text="Student results" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">What members say</h2>
    <p class="text-gray-500 mt-4 text-lg leading-relaxed">Real words from people following the process. Results vary — trading involves risk.</p>
  </div>
  <div class="grid sm:grid-cols-3 gap-5">
    {testimonials.map((t) => (
      <figure class="reveal rounded-2xl border border-gray-200 bg-white p-6 flex flex-col">
        <div class="flex gap-0.5 text-accent mb-4">
          {[1,2,3,4,5].map(() => (<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.28 3.95a1 1 0 00.95.69h4.15c.97 0 1.37 1.24.59 1.81l-3.36 2.44a1 1 0 00-.36 1.12l1.28 3.95c.3.92-.75 1.69-1.54 1.12l-3.36-2.44a1 1 0 00-1.18 0l-3.36 2.44c-.79.57-1.84-.2-1.54-1.12l1.28-3.95a1 1 0 00-.36-1.12L2.03 9.38c-.78-.57-.38-1.81.59-1.81h4.15a1 1 0 00.95-.69l1.28-3.95z"/></svg>))}
        </div>
        <blockquote class="text-sm text-gray-700 leading-relaxed flex-1">"{t.quote}"</blockquote>
        <figcaption class="mt-5 pt-4 border-t border-gray-100">
          <p class="text-sm font-semibold text-gray-950">{t.name}</p>
          <p class="text-xs text-gray-500">{t.role}</p>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
