---
import Eyebrow from './Eyebrow.astro';
const steps = [
  { n: "1", title: "Choose your plan", desc: "Pick the full bundle and check out securely in under a minute." },
  { n: "2", title: "Instant access", desc: "Your account unlocks the moment your payment clears — no waiting." },
  { n: "3", title: "Watch anywhere", desc: "Stream every class in your private members area, on any device, at your pace." }
];
---
<section id="how" class="max-w-5xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="max-w-xl mb-14 reveal">
    <Eyebrow text="How it works" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">From payment to first lesson in a minute.</h2>
    <p class="text-gray-500 mt-4 text-lg leading-relaxed">A clean, private members area. No clutter, no friction — just your classes.</p>
  </div>
  <div class="grid sm:grid-cols-3 gap-x-8 gap-y-10">
    {steps.map((s) => (
      <div class="reveal">
        <div class="w-9 h-9 rounded-lg bg-gray-950 text-white text-sm font-semibold flex items-center justify-center">{s.n}</div>
        <h3 class="mt-5 font-semibold text-[15px] text-gray-950">{s.title}</h3>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">{s.desc}</p>
      </div>
    ))}
  </div>
</section>
