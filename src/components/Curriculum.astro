---
import ChapterAccordion from './ChapterAccordion.astro';
import Eyebrow from './Eyebrow.astro';
const { chapters } = Astro.props;
const totalClasses = chapters.reduce((s, c) => s + (c.classCount || (c.classes?.length ?? 0)), 0);
---
<section id="curriculum" class="max-w-4xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="max-w-xl mb-12 reveal">
    <Eyebrow text="The curriculum" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">7 chapters. {totalClasses} classes. One path.</h2>
    <p class="text-gray-500 mt-4 text-lg leading-relaxed">Preview every chapter and class. Open any chapter to see what is inside — then unlock it, or take the whole thing.</p>
  </div>
  <div class="space-y-3.5">
    {chapters.map((chapter, i) => <ChapterAccordion chapter={chapter} index={i + 1} />)}
  </div>
  <div class="mt-12 rounded-2xl border border-gray-200 bg-gray-50 px-6 py-10 text-center reveal">
    <p class="text-lg font-semibold text-gray-950">You have seen the map. Unlock the whole thing.</p>
    <p class="text-sm text-gray-500 mt-2 max-w-md mx-auto">Buy chapter by chapter for $99 — or get all {totalClasses} classes for $79.</p>
    <a href="#pricing" class="inline-block mt-6 rounded-lg bg-gray-950 text-white text-sm font-medium px-7 py-3.5 hover:bg-gray-800 transition-colors">Unlock all 7 chapters — $79</a>
  </div>
</section>
