---
const { chapter, index } = Astro.props;
const { id, title, hook, thumbnail, price, classCount, classes } = chapter;
const img = thumbnail && thumbnail.length > 0 ? thumbnail : `https://placehold.co/640x360/f8fafc/cbd5e1?text=Chapter+${index}`;
const open = index === 1;
---
<details class="group rounded-2xl border border-gray-200 bg-white overflow-hidden hover:border-gray-300 transition-colors" open={open}>
  <summary class="flex items-center gap-4 p-4 sm:p-5 cursor-pointer list-none">
    <span class="hidden sm:flex w-8 h-8 shrink-0 rounded-full border border-gray-200 items-center justify-center text-xs font-semibold text-gray-400">{String(index).padStart(2,"0")}</span>
    <div class="relative w-28 sm:w-36 shrink-0 rounded-lg overflow-hidden bg-gray-50">
      <img src={img} alt={`Chapter ${index}`} loading="lazy" decoding="async" class="w-full aspect-video object-cover" onerror={`this.src='https://placehold.co/640x360/f8fafc/cbd5e1?text=Chapter+${index}'`} />
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-[11px] font-medium text-accent uppercase tracking-wide">{classCount} classes</span>
        <span class="inline-flex items-center gap-1 text-[11px] font-medium text-gray-400">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>Locked
        </span>
      </div>
      <h3 class="font-semibold text-[15px] sm:text-base text-gray-950 leading-snug mt-1 truncate">{title}</h3>
      <p class="text-sm text-gray-500 mt-0.5 leading-relaxed line-clamp-1 sm:line-clamp-2">{hook}</p>
    </div>
    <div class="flex flex-col items-end gap-1.5 shrink-0">
      <span class="text-sm font-semibold text-gray-950">${price}</span>
      <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </summary>
  <div class="border-t border-gray-100 divide-y divide-gray-50">
    {classes.map((c, i) => (
      <div class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50/60 transition-colors">
        <span class="text-xs font-medium text-gray-400 w-6 shrink-0">{String(i + 1).padStart(2, "0")}</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-950 truncate">{c.title}</p>
          <p class="text-xs text-gray-500 truncate">{c.hook}</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      </div>
    ))}
    <div class="flex items-center justify-between gap-3 px-5 py-3.5 bg-gray-50/60">
      <a href={`/checkout?chapter=${id}`} class="text-sm font-medium text-gray-700 hover:text-gray-950 transition-colors">Unlock Chapter {index} — ${price}</a>
      <a href="#pricing" class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:opacity-80 transition-opacity">Or get all 7 for $79
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</details>
