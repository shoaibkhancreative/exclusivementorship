---
import chapters from '../data/chapters.json';
import Eyebrow from './Eyebrow.astro';
const separateTotal = chapters.reduce((s, c) => s + (c.price || 0), 0);
const bundle = 79;
const saving = separateTotal - bundle;
---
<section id="pricing" class="max-w-5xl mx-auto px-6 py-24 border-t border-gray-100">
  <div class="text-center max-w-xl mx-auto mb-14 reveal">
    <Eyebrow text="Pricing" />
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-3">One simple choice</h2>
    <p class="text-gray-500 mt-4 text-lg leading-relaxed">Buy chapters separately for ${separateTotal} — or unlock all 7 chapters and 99 classes for ${bundle}.</p>
  </div>
  <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-5 items-stretch">
    <div class="rounded-2xl p-8 border border-gray-200 bg-white flex flex-col">
      <h3 class="font-semibold text-gray-950">Tier 1 — Chapter by chapter</h3>
      <p class="mt-1 text-sm text-gray-500">Unlock individual chapters as you go.</p>
      <p class="mt-6 flex items-baseline gap-1"><span class="text-4xl font-bold tracking-tight text-gray-950">${separateTotal}</span><span class="text-sm text-gray-500">for all 7 separately</span></p>
      <ul class="mt-6 space-y-2.5 flex-1">
        {chapters.map((c, i) => (
          <li class="flex items-center justify-between text-sm">
            <span class="text-gray-600 truncate pr-3">Ch. {i + 1} · {c.title}</span>
            <span class="text-gray-400 shrink-0">${c.price}</span>
          </li>
        ))}
      </ul>
      <p class="mt-5 text-xs text-gray-400">Priority Support available as a +$8 add-on at checkout.</p>
      <a href="/checkout?tier=1" class="block text-center mt-6 py-3 rounded-lg font-medium text-sm border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">Choose chapters</a>
    </div>
    <div class="relative rounded-2xl p-8 border-2 border-gray-950 bg-gray-950 text-white flex flex-col shadow-xl">
      <span class="absolute -top-3 left-8 text-[11px] font-semibold bg-accent text-white rounded-full px-3 py-1">BEST VALUE · SAVE ${saving}</span>
      <h3 class="font-semibold text-white">Tier 2 — Full bundle</h3>
      <p class="mt-1 text-sm text-gray-400">All 7 chapters, all 99 classes, unlocked instantly.</p>
      <p class="mt-6 flex items-baseline gap-2"><span class="text-4xl font-bold tracking-tight">${bundle}</span><span class="text-sm text-gray-500 line-through">${separateTotal}</span></p>
      <ul class="mt-8 space-y-3 flex-1">
        <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg><span class="text-gray-200">All 7 chapters · 99 classes</span></li>
        <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg><span class="text-gray-200">Priority Support included free</span></li>
        <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg><span class="text-gray-200">Save ${saving} vs buying chapters</span></li>
        <li class="flex items-start gap-2.5 text-sm"><svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg><span class="text-gray-200">Future classes included</span></li>
      </ul>
      <a href="/checkout?tier=2" class="block text-center mt-8 py-3.5 rounded-lg font-semibold text-sm bg-white text-gray-950 hover:bg-gray-100 transition-colors">Get the full bundle</a>
      <p class="text-center text-xs text-gray-500 mt-3">Secure checkout · Instant access · Cancel anytime</p>
    </div>
  </div>
</section>
