---
import type { Chapter } from "@/data/chapters";

interface Props {
  chapter: Chapter;
  index: number;
}

const { chapter, index } = Astro.props;
const previewCount = 3;
const previewClasses = chapter.classList.slice(0, previewCount);
const remainingClasses = chapter.classList.slice(previewCount);
const hasMore = remainingClasses.length > 0;
---

<article
  class="chapter-card group relative rounded-2xl border border-neutral-800 bg-neutral-900/40 backdrop-blur overflow-hidden transition-all duration-500 hover:border-yellow-500/40 hover:shadow-2xl hover:shadow-yellow-500/5"
  data-chapter={chapter.id}
>
  <!-- Thumbnail with gradient overlay -->
  <div class={`relative aspect-[16/9] overflow-hidden bg-gradient-to-br ${chapter.gradient}`}>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.08),transparent_50%)]"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-8xl font-black text-white/5 tracking-tighter">0{chapter.id}</div>
    </div>
    <div class="absolute top-4 left-4 flex items-center gap-2">
      <span class="px-2.5 py-1 rounded-md bg-black/60 backdrop-blur border border-white/10 text-[10px] font-mono text-yellow-500 uppercase tracking-wider">
        Chapter {String(chapter.id).padStart(2, "0")}
      </span>
    </div>
    <div class="absolute top-4 right-4">
      <span class="px-2.5 py-1 rounded-md bg-black/60 backdrop-blur border border-white/10 text-xs text-neutral-300">
        {chapter.classes} classes
      </span>
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/90 to-transparent">
      <h3 class="text-xl md:text-2xl font-bold text-white leading-tight">{chapter.title}</h3>
      <p class="mt-1 text-sm text-neutral-400">{chapter.tagline}</p>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <!-- Hooks -->
    <div class="flex flex-wrap gap-2 mb-6">
      {chapter.hooks.map((h) => (
        <span class="px-2.5 py-1 rounded-md bg-neutral-800/60 border border-neutral-700 text-[11px] text-neutral-300">
          {h}
        </span>
      ))}
    </div>

    <!-- Class list preview -->
    <div class="space-y-2">
      <div class="flex items-center justify-between mb-3">
        <h4 class="text-xs uppercase tracking-wider text-neutral-500 font-semibold">What you'll learn</h4>
        <span class="text-[10px] text-neutral-600">{chapter.classList.length} lessons</span>
      </div>

      <!-- Preview (always visible) -->
      <div class="space-y-1.5">
        {previewClasses.map((cls, i) => (
          <div class="class-item flex items-start gap-3 p-2.5 rounded-lg hover:bg-neutral-800/40 transition">
            <div class="flex-shrink-0 w-7 h-7 rounded-md bg-neutral-800 border border-neutral-700 flex items-center justify-center text-[11px] font-mono text-neutral-400 group-hover:text-yellow-500 group-hover:border-yellow-500/40 transition">
              {String(i + 1).padStart(2, "0")}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <p class="text-sm font-medium text-neutral-200 truncate">{cls.title}</p>
                {cls.duration && (
                  <span class="text-[10px] text-neutral-600 flex-shrink-0">{cls.duration}</span>
                )}
              </div>
              <p class="text-xs text-neutral-500 truncate">{cls.subtitle}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Hidden classes (revealed by JS) -->
      {hasMore && (
        <div class="hidden-classes space-y-1.5 overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-out">
          {remainingClasses.map((cls, i) => (
            <div class="class-item flex items-start gap-3 p-2.5 rounded-lg hover:bg-neutral-800/40 transition">
              <div class="flex-shrink-0 w-7 h-7 rounded-md bg-neutral-800 border border-neutral-700 flex items-center justify-center text-[11px] font-mono text-neutral-400 group-hover:text-yellow-500 group-hover:border-yellow-500/40 transition">
                {String(i + 1 + previewCount).padStart(2, "0")}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2">
                  <p class="text-sm font-medium text-neutral-200 truncate">{cls.title}</p>
                  {cls.duration && (
                    <span class="text-[10px] text-neutral-600 flex-shrink-0">{cls.duration}</span>
                  )}
                </div>
                <p class="text-xs text-neutral-500 truncate">{cls.subtitle}</p>
              </div>
            </div>
          ))}
        </div>
      )}

      {hasMore && (
        <button
          class="load-more-btn mt-3 w-full flex items-center justify-center gap-2 py-2.5 rounded-lg border border-dashed border-neutral-700 hover:border-yellow-500/50 hover:bg-yellow-500/5 text-xs text-neutral-400 hover:text-yellow-500 font-medium transition-all"
          data-total={remainingClasses.length}
        >
          <span class="btn-label">Load {remainingClasses.length} more classes</span>
          <svg class="btn-icon w-3.5 h-3.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>
      )}
    </div>

    <!-- Footer -->
    <div class="mt-6 pt-5 border-t border-neutral-800 flex items-center justify-between">
      <div>
        <div class="text-2xl font-bold text-white">${chapter.price}</div>
        <div class="text-[10px] text-neutral-500 uppercase tracking-wider">Individual price</div>
      </div>
      <a
        href={`/checkout?tier=1&chapter=${chapter.slug}`}
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-neutral-800 hover:bg-yellow-500 hover:text-black text-sm font-semibold text-white transition-all group/btn"
      >
        Get Chapter
        <svg class="w-4 h-4 transition-transform group-hover/btn:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>
