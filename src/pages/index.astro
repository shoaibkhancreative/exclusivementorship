---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ChapterCard from "@/components/ChapterCard.astro";
import LoadMoreScript from "@/components/LoadMoreScript.astro";
import { chapters, pricing } from "@/data/chapters";
---
<BaseLayout>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_-20%,rgba(212,175,55,0.15),transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)] bg-[size:60px_60px] opacity-30 [mask-image:radial-gradient(ellipse_at_center,black,transparent_70%)]"></div>

    <div class="container-x relative py-24 md:py-36 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-neutral-800 bg-neutral-900/50 text-xs text-neutral-400 mb-6">
        <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
        Exclusive Mentorship Program
      </div>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
        Trade like the <span class="text-yellow-500">1%</span>.<br/>
        Not the crowd.
      </h1>
      <p class="mt-6 text-lg text-neutral-400 max-w-2xl mx-auto">
        7 chapters. 99 scripted classes. One complete institutional trading system — built for serious traders only.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#pricing" class="btn-primary">Get Full Access — ${pricing.tier2Bundle}</a>
        <a href="#chapters" class="btn-secondary">Explore Curriculum</a>
      </div>

      <!-- Stats bar -->
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">7</div>
          <div class="text-xs text-neutral-500 uppercase tracking-wider mt-1">Chapters</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">99</div>
          <div class="text-xs text-neutral-500 uppercase tracking-wider mt-1">Classes</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white">40+</div>
          <div class="text-xs text-neutral-500 uppercase tracking-wider mt-1">Hours Content</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-yellow-500">1</div>
          <div class="text-xs text-neutral-500 uppercase tracking-wider mt-1">Complete System</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CHAPTERS -->
  <section id="chapters" class="relative">
    <div class="container-x py-24">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-yellow-500/20 bg-yellow-500/5 text-xs text-yellow-500 mb-4 uppercase tracking-wider">
          The Curriculum
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">Every lesson. Every edge.</h2>
        <p class="mt-4 text-neutral-400">7 chapters, meticulously designed to take you from foundation to prop-firm ready trader.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {chapters.map((ch, i) => <ChapterCard chapter={ch} index={i} />)}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="relative">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(212,175,55,0.08),transparent_60%)]"></div>
    <div class="container-x relative py-24">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-yellow-500/20 bg-yellow-500/5 text-xs text-yellow-500 mb-4 uppercase tracking-wider">
          Pricing
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">Choose Your Path</h2>
        <p class="mt-4 text-neutral-400">Pay chapter by chapter — or unlock everything and save $20.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <!-- Tier 1 -->
        <div class="card relative">
          <h3 class="text-sm text-neutral-500 uppercase tracking-wider mb-2">Tier 1</h3>
          <div class="text-xl font-semibold mb-1">Chapter by Chapter</div>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-5xl font-bold">${pricing.tier1Total}</span>
            <span class="text-sm text-neutral-500">if all bought</span>
          </div>
          <ul class="space-y-3 text-sm text-neutral-400 mb-8">
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Buy any chapter individually</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Chapter-specific Telegram access</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Lifetime access to purchased chapters</li>
            <li class="flex gap-2"><span class="text-neutral-600">+</span>Priority support optional (+$8)</li>
          </ul>
          <a href="#chapters" class="btn-secondary w-full">Browse Chapters</a>
        </div>
        <!-- Tier 2 -->
        <div class="card relative border-yellow-500/50 bg-gradient-to-b from-yellow-500/5 to-transparent">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-yellow-500 text-black text-xs font-bold">MOST POPULAR</div>
          <h3 class="text-sm text-yellow-500 uppercase tracking-wider mb-2">Tier 2 — Full Bundle</h3>
          <div class="text-xl font-semibold mb-1">Complete Mentorship</div>
          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-5xl font-bold text-yellow-500">${pricing.tier2Bundle}</span>
            <span class="text-lg text-neutral-500 line-through">${pricing.tier1Total}</span>
          </div>
          <div class="text-xs text-green-500 mb-6">Save ${pricing.savings} + Priority Support included</div>
          <ul class="space-y-3 text-sm text-neutral-300 mb-8">
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>All 7 chapters — 99 classes</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Main Telegram channel access</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Priority support included ($8 value)</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>7-day money back guarantee</li>
            <li class="flex gap-2"><span class="text-yellow-500">✓</span>Lifetime access</li>
          </ul>
          <a href="/checkout?tier=2" class="btn-primary w-full">Get Full Access — ${pricing.tier2Bundle}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="container-x py-24">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-yellow-500/20 bg-yellow-500/5 text-xs text-yellow-500 mb-4 uppercase tracking-wider">
        FAQ
      </div>
      <h2 class="text-3xl md:text-5xl font-bold">Common Questions</h2>
    </div>
    <div class="max-w-2xl mx-auto space-y-3">
      {[
        {q: "How is the content delivered?", a: "সব ভিডিও private Telegram channel এ। Payment successful হলে automatic single-use invite link পাবেন।"},
        {q: "Can I get a refund?", a: "Full bundle (Tier 2) তে 7-day refund guarantee। Individual chapters তে refund নেই।"},
        {q: "What if I don't understand crypto payment?", a: "Request a support call — WhatsApp এ direct guide করে দেবো।"},
        {q: "Are there any free classes?", a: "No. This is a premium mentorship — no free content, no fluff।"}
      ].map((item) => (
        <details class="card group cursor-pointer">
          <summary class="flex justify-between items-center font-medium list-none">
            {item.q}
            <span class="text-yellow-500 group-open:rotate-45 transition text-xl">+</span>
          </summary>
          <p class="mt-3 text-sm text-neutral-400">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <LoadMoreScript />
</BaseLayout>
