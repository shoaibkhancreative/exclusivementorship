---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Login - PEM">
  <section class="container-x py-24 max-w-md mx-auto">
    <h1 class="text-3xl font-bold mb-8 text-center">Welcome Back</h1>
    <form class="card space-y-4">
      <div>
        <label class="text-sm text-neutral-400">Email</label>
        <input type="email" class="mt-1 w-full px-4 py-3 rounded-lg bg-neutral-950 border border-neutral-800 focus:border-yellow-500 outline-none" />
      </div>
      <div>
        <label class="text-sm text-neutral-400">Password</label>
        <input type="password" class="mt-1 w-full px-4 py-3 rounded-lg bg-neutral-950 border border-neutral-800 focus:border-yellow-500 outline-none" />
      </div>
      <button class="btn-primary w-full">Login</button>
    </form>
  </section>
</BaseLayout>
