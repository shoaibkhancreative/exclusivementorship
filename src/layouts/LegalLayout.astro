---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title, updated } = Astro.props;
---
<BaseLayout title={`${title} — Exclusive Mentorship`}>
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-20">
    <a href="/" class="text-sm text-gray-500 hover:text-gray-950 transition-colors">← Back to home</a>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-950 mt-6">{title}</h1>
    {updated && <p class="text-sm text-gray-400 mt-2">Last updated: {updated}</p>}
    <div class="mt-8 space-y-6 text-[15px] text-gray-600 leading-relaxed [&_h2]:text-gray-950 [&_h2]:font-semibold [&_h2]:text-lg [&_h2]:mt-8 [&_h2]:mb-2">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
